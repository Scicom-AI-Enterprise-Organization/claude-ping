# Copy to .env and fill in — `.env` is gitignored, `.env.example` is committed.
#
# `claude-ping env-sync` reads each value from your shell environment first, then
# falls back to this file, and pushes the ones named in "secret_keys"
# (claude-ping.json) to the remote box. Leave "secret_keys" empty to sync every
# key defined here. `claude-ping monitor` also reads WANDB_* / HF_TOKEN from here.

# WandB (for `claude-ping monitor`)
WANDB_API_KEY=
WANDB_ENTITY=

# HuggingFace (monitor + any HF pulls the remote job does)
HF_TOKEN=

# Any custom secret/env your remote job needs: add it here, then list its name in
# "secret_keys" (or leave secret_keys empty to sync everything in this file).
MY_CUSTOM_SECRET=
